# TinaCMS Cloud configuration
# Get these values from https://app.tina.io → your project → Tokens

# The client ID for your TinaCMS project (safe to expose publicly)
NEXT_PUBLIC_TINA_CLIENT_ID=your-client-id-here

# Content read-only token (used at build time for fetching content)
TINA_TOKEN=your-content-readonly-token-here

# Git branch to use for content
GITHUB_BRANCH=main
